---
import '../styles/global.css';
import LogoMark from '../components/LogoMark.astro';

interface Props {
  title: string;
  section?: string;
}

const { title, section } = Astro.props;
const sections = [
  { id: '01-foundation', label: '01 · Фундамент' },
  { id: '02-logo', label: '02 · Логотип' },
  { id: '03-color', label: '03 · Цвет' },
  { id: '04-typography', label: '04 · Типографика' },
  { id: '05-tokens', label: '05 · Токены' },
  { id: '06-application', label: '06 · Применение' },
];
---
<!doctype html>
<html lang="ru" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} · Брендбук Сергея Дмитриева</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Golos+Text:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
    <script is:inline>
      // Apply saved theme before paint to avoid FOUC. Default: dark (site's primary theme).
      const saved = localStorage.getItem('brandbook-theme');
      const theme = saved === 'light' || saved === 'dark' ? saved : 'dark';
      document.documentElement.setAttribute('data-theme', theme);
    </script>
  </head>
  <body>
    <header class="site-header">
      <div class="container site-header__inner">
        <a href="/" class="site-logo">
          <LogoMark size={28} />
          <span>Дмитриев</span>
        </a>
        <nav class="site-nav">
          {sections.map((s) => (
            <a
              href={`/${s.id}`}
              class:list={[{ active: section === s.id }]}
            >{s.label}</a>
          ))}
        </nav>
        <button
          class="theme-toggle"
          type="button"
          aria-label="Переключить тему"
          title="Переключить тему"
        >
          <svg class="theme-toggle__icon theme-toggle__icon--sun" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="12" cy="12" r="4" />
            <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41" />
          </svg>
          <svg class="theme-toggle__icon theme-toggle__icon--moon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
          </svg>
        </button>
      </div>
    </header>
    <main class="container">
      <slot />
    </main>
    <script is:inline>
      // Toggle handler — flips html[data-theme], persists to localStorage.
      // TemplateCard previews carry their own data-theme and are unaffected.
      const btn = document.querySelector('.theme-toggle');
      btn?.addEventListener('click', () => {
        const next = document.documentElement.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
        document.documentElement.setAttribute('data-theme', next);
        localStorage.setItem('brandbook-theme', next);
      });
    </script>
    <style>
      .site-header {
        border-bottom: 1px solid var(--border);
        position: sticky;
        top: 0;
        background: var(--canvas);
        z-index: 10;
      }
      .site-header__inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        height: 60px;
        gap: 16px;
      }
      .site-logo {
        display: flex;
        align-items: center;
        gap: 10px;
        font-weight: 700;
        color: var(--text);
        font-size: 1rem;
      }
      .site-nav {
        display: flex;
        gap: 18px;
        font-size: var(--text-small);
        color: var(--text-mute);
        margin-left: auto;
      }
      .site-nav a {
        color: var(--text-mute);
      }
      .site-nav a:hover,
      .site-nav a.active {
        color: var(--amber-500);
      }
      .theme-toggle {
        flex-shrink: 0;
        width: 34px;
        height: 34px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 8px;
        color: var(--text-dim);
        cursor: pointer;
        transition: color .15s, border-color .15s;
      }
      .theme-toggle:hover {
        color: var(--amber-500);
        border-color: var(--amber-500);
      }
      /* Show sun in dark theme (action: switch to light), moon in light theme. */
      .theme-toggle__icon { display: none; }
      :global([data-theme="dark"]) .theme-toggle__icon--sun { display: block; }
      :global([data-theme="light"]) .theme-toggle__icon--moon { display: block; }
      @media (max-width: 760px) {
        .site-nav { display: none; }
      }
    </style>
  </body>
</html>
